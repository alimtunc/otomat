{
  "name": "@otomat/local-daemon",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "imports": {
    "#bootstrap": "./src/bootstrap.ts",
    "#api": "./src/api/index.ts",
    "#api/*": "./src/api/*.ts",
    "#events": "./src/events/index.ts",
    "#events/*": "./src/events/*.ts",
    "#git": "./src/git/index.ts",
    "#git/*": "./src/git/*.ts",
    "#github": "./src/github/index.ts",
    "#github/*": "./src/github/*.ts",
    "#review": "./src/review/index.ts",
    "#review/*": "./src/review/*.ts",
    "#runtime": "./src/runtime/index.ts",
    "#runtime/*": "./src/runtime/*.ts",
    "#supervisor": "./src/supervisor/index.ts",
    "#supervisor/*": "./src/supervisor/*.ts"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "vitest run",
    "start": "tsx src/index.ts",
    "start:dist": "node dist/index.js",
    "smoke:dist": "node scripts/smoke-dist.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "@hono/zod-validator": "^0.9.0",
    "@otomat/db": "workspace:*",
    "@otomat/domain": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.29",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsdown": "^0.22.9",
    "tsx": "^4.23.1",
    "vitest": "^4.1.10"
  }
}

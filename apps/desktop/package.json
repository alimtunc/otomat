{
  "name": "@otomat/desktop",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/main/index.js",
  "imports": {
    "#shared/*": "./src/shared/*.ts",
    "#main/*": "./src/main/*.ts",
    "#preload/*": "./src/preload/*.ts"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "vitest run",
    "start": "electron .",
    "prepare-daemon": "node scripts/prepare-daemon.mjs",
    "package:mac": "node scripts/package-mac.mjs"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.0",
    "@otomat/domain": "workspace:*",
    "@types/node": "^26.1.1",
    "electron": "^43.0.0",
    "electron-builder": "^26.0.0",
    "tsdown": "^0.22.5",
    "vitest": "^4.1.10"
  }
}

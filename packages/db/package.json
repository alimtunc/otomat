{
  "name": "@otomat/db",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist",
    "drizzle"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "vitest run",
    "generate": "drizzle-kit generate",
    "migrate": "tsx src/bin/migrate.ts"
  },
  "dependencies": {
    "@otomat/domain": "workspace:*",
    "better-sqlite3": "^11.8.1",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.2",
    "vitest": "^2.1.8"
  }
}

{
  "name": "@otomat/client",
  "version": "0.0.0",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "imports": {
    "#client/*": "./src/*.ts"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@otomat/domain": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.10"
  }
}

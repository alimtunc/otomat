      "import": "./dist/types.js"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "typecheck": "tsgo -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "vitest": "^4.1.9"
  }
}
